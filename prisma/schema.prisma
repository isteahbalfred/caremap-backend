generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(PATIENT)
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  PHARMACIEN
  CLINICIEN
  PATIENT
}

model Medication {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       Float
  stock       Int
}

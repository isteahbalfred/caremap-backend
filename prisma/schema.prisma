generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  password     String
  firstName    String
  lastName     String
  role         UserRole  @default(PATIENT)
  isActive     Boolean   @default(true)
  refreshToken String?
  googleId     String?   @unique    // ← AJOUTER ICI
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  pharmacy     Pharmacy?
  clinic       Clinic?
}

model Pharmacy {
  id          String            @id @default(uuid())
  name        String
  address     String
  city        String
  phone       String
  latitude    Float
  longitude   Float
  logoUrl     String?
  isValidated Boolean           @default(false)
  isActive    Boolean           @default(true)
  adminId     String            @unique
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  medications MedicationStock[]
  admin       User              @relation(fields: [adminId], references: [id])

  @@index([city])
  @@index([isValidated, isActive])
}

model Category {
  id          String       @id @default(uuid())
  name        String       @unique
  medications Medication[]
}

model Medication {
  id          String            @id @default(uuid())
  name        String
  genericName String?
  description String?
  imageUrl    String?
  categoryId  String
  category    Category          @relation(fields: [categoryId], references: [id])
  stocks      MedicationStock[]

  @@index([name])
  @@index([categoryId])
}

model MedicationStock {
  id           String     @id @default(uuid())
  pharmacyId   String
  medicationId String
  quantity     Int        @default(0)
  price        Decimal    @db.Decimal(10, 2)
  threshold    Int        @default(10)
  isAvailable  Boolean    @default(true)
  updatedAt    DateTime   @updatedAt
  medication   Medication @relation(fields: [medicationId], references: [id])
  pharmacy     Pharmacy   @relation(fields: [pharmacyId], references: [id])

  @@unique([pharmacyId, medicationId])
}

model Clinic {
  id          String   @id @default(uuid())
  name        String
  address     String
  city        String
  phone       String
  latitude    Float
  longitude   Float
  logoUrl     String?
  isValidated Boolean  @default(false)
  isActive    Boolean  @default(true)
  adminId     String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  admin       User     @relation(fields: [adminId], references: [id])

  @@index([city])
}

enum UserRole {
  PATIENT
  PHARMACY_ADMIN
  CLINIC_ADMIN
  SUPER_ADMIN
}
